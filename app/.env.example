# ─── Server Configuration ────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development            # development | production | test
LOG_LEVEL=info                  # error | warn | info | http | debug

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (use * for open access in dev only)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── Application Metadata ───────────────────────────────────────────────────
# These are injected automatically by the Jenkins pipeline at build time.
# For local development you can set them manually.
APP_VERSION=1.0.0
GIT_COMMIT=unknown
BUILD_NUMBER=local
BUILD_DATE=unknown

# ─── AWS Metadata ────────────────────────────────────────────────────────────
# Populated by the EC2 instance metadata service in production.
# Leave as-is for local development.
AWS_REGION=us-east-1
INSTANCE_ID=local
